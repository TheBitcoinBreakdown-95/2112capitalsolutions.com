---
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (path: string) => {
  if (path === '/' && pathname === '/') return 'page';
  if (path !== '/' && pathname.startsWith(path)) return 'page';
  return undefined;
};

const navItems = [
  { href: '/services', label: 'Services' },
  { href: '/methodology', label: 'Methodology' },
  { href: '/guides', label: 'Guides' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brandmark" aria-label="2112 Capital Solutions home">
      <span class="bar"></span>2112
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {navItems.map(item => (
          <li><a href={item.href} aria-current={isActive(item.href)}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <button class="hamburger" type="button" aria-label="Menu" aria-controls="mobile-nav" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile primary">
    <ul>
      {navItems.map(item => (
        <li><a href={item.href} aria-current={isActive(item.href)}>{item.label}</a></li>
      ))}
    </ul>
  </nav>
</header>
