---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="2112 Capital Solutions"
  description="Sovereignty consulting. Bitcoin integration for individuals, organizations, and operating businesses."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-mark">
        <div class="lockup-v14 s-hero">
          <div class="lbar"></div>
          <div class="stack">
            <div class="num">2112</div>
            <div class="sub">Capital Solutions</div>
          </div>
        </div>
      </div>
      <div class="classify">SOVEREIGNTY CONSULTING</div>
    </div>
  </section>

  <!-- SERVICES PREVIEW -->
  <section class="module">
    <div class="container">
      <div class="module-classify">
        <span>MODULE 01 — SERVICES</span>
        <span class="ref">PROT.001 / PROT.002 / PROT.003</span>
      </div>
      <h2 class="module-title">Hands-on integration. <em>Documented deliverables.</em></h2>
      <p class="module-lede">Each engagement is scoped against an explicit deliverable list. Pricing visible at intake. Retainer relationships available for ongoing infrastructure.</p>

      <div class="card-grid">
        <a href="/services#custody" class="card">
          <div class="card-eyebrow">PROT.001 · CUSTODY</div>
          <div class="card-title">Self-custody setup &amp; key ceremony</div>
          <p class="card-excerpt">Migration from exchange custody to self-held cold storage. Hardware, seed, multisig, and recovery rehearsal in one session.</p>
          <div class="card-meta"><span class="signal">$100+</span><span>2–6 HRS</span></div>
        </a>
        <a href="/services#infrastructure" class="card">
          <div class="card-eyebrow">PROT.002 · INFRASTRUCTURE</div>
          <div class="card-title">Node + Lightning deployment</div>
          <p class="card-excerpt">Full-node provisioning, security hardening, Lightning channel topology, ongoing maintenance via retainer.</p>
          <div class="card-meta"><span class="signal">$500+</span><span>1–2 DAYS</span></div>
        </a>
        <a href="/services#advisory" class="card">
          <div class="card-eyebrow">PROT.003 · ADVISORY</div>
          <div class="card-title">Treasury · integration · education</div>
          <p class="card-excerpt">Bitcoin treasury planning, custom integration design, team education for engineering and operations groups.</p>
          <div class="card-meta"><span class="signal">$100/HR</span><span>HOURLY</span></div>
        </a>
      </div>
    </div>
  </section>

  <!-- ABOUT PREVIEW -->
  <section class="module">
    <div class="container">
      <div class="module-classify">
        <span>MODULE 02 — WHAT WE DO</span>
        <span class="ref">MISSION</span>
      </div>
      <h2 class="module-title">Streamline <em>sovereignty.</em></h2>
      <p class="module-lede">2112 Capital Solutions provides hands-on Bitcoin integration consulting for individuals, organizations, and operating businesses. We deliver comprehensive Bitcoin education and promote best practices so others can thrive in the great digital transformation.</p>
      <p class="module-lede">Build and protect your wealth outside of the traditional financial system.</p>
    </div>
  </section>
</BaseLayout>
