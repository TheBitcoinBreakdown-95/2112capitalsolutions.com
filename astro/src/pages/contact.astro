---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact — 2112 Capital Solutions"
  description="Direct email or message. We respond within one business day. The operator on the message is the operator on the engagement."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="classify">CONTACT</div>
      <h1>Email <em>direct.</em></h1>
      <div class="hero-sub">
        No intermediaries · The person you talk to is the person doing the work
      </div>
    </div>
  </section>

  <!-- DIRECT EMAIL -->
  <section class="module">
    <div class="container">
      <div class="module-classify">
        <span>DIRECT</span>
        <span class="ref">RESPONSE WITHIN ONE BUSINESS DAY</span>
      </div>

      <div class="protocol">
        <div class="protocol-id">A<span class="label">EMAIL</span></div>
        <div class="protocol-body">
          <h4>Direct email</h4>
          <p>For most inquiries, email is the fastest path. We respond within one business day. Be specific about where you are, what you have, and what success looks like — the more concrete, the faster we can scope.</p>
        </div>
        <div class="protocol-spec">
          <b><a href="mailto:thebitcoinbreakdown@gmail.com" style="color: var(--text); border: none;">thebitcoinbreakdown<br>@gmail.com</a></b>
          <span class="ln"><span>Response:</span> 1 business day</span>
        </div>
      </div>
    </div>
  </section>

  <!-- INTAKE FORM -->
  <section class="module">
    <div class="container">
      <div class="module-classify">
        <span>OR WRITE TO US</span>
        <span class="ref">VIA FORM</span>
      </div>
      <h2 class="module-title">Send a <em>message.</em></h2>
      <p class="module-lede">Tell us where you are, what you have, and what success looks like. We'll reply with a proposed time for a call.</p>

      <form class="form-grid" action="mailto:thebitcoinbreakdown@gmail.com" method="post" enctype="text/plain">
        <div class="field">
          <label for="name">Name</label>
          <input id="name" name="name" type="text" required placeholder="Your name" />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input id="email" name="email" type="email" required placeholder="hello@yourdomain.com" />
        </div>
        <div class="field">
          <label for="org">Organization (optional)</label>
          <input id="org" name="org" type="text" placeholder="For engagement memos" />
        </div>
        <div class="field">
          <label for="topic">Topic of interest</label>
          <select id="topic" name="topic">
            <option value="custody">Self-custody setup</option>
            <option value="infrastructure">Node + Lightning</option>
            <option value="advisory">Treasury / advisory</option>
            <option value="ai">AI workflow</option>
            <option value="privacy">Privacy stack</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="field">
          <label for="msg">What you have, what you want, what done looks like</label>
          <textarea id="msg" name="message" required placeholder="Be specific. The more concrete, the faster we can scope."></textarea>
        </div>
        <div>
          <button type="submit" class="btn btn--primary">Send</button>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>
