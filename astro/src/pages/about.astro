---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="About — 2112 Capital Solutions"
  description="Boutique consulting firm. Founded 2023 to deliver hands-on sovereignty services to individuals and operating businesses. Bitcoin services lead today; AI, privacy, and self-hosted infrastructure layer in."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="classify">MODULE 03 — ENTITY · 2112 CAPITAL SOLUTIONS LLC</div>
      <h1>About <em>2112.</em></h1>
      <div class="hero-sub">
        Boutique consulting · Founded 2023 · Hands-on sovereignty services · Direct retainer engagements
      </div>
    </div>
  </section>

  <!-- POSITIONING -->
  <section class="module">
    <div class="container">
      <div class="module-classify">
        <span>POSITIONING</span>
        <span class="ref">WHO WE WORK WITH</span>
      </div>
      <h2 class="module-title">Sovereignty consulting for people <em>who actually own their tools.</em></h2>
      <p class="module-lede">2112 Capital Solutions is a boutique consulting firm. Founded 2023 in New Jersey. Bitcoin services lead today; AI workflow, privacy, and self-hosted infrastructure layer in as client demand materializes. Behind the scenes, the LLC is also the legal shell for The Bitcoin Breakdown's media operation.</p>

      <div class="readout">
        <div class="readout-cell">
          <div class="readout-label">Entity</div>
          <div class="readout-value">2112 Capital Solutions LLC</div>
        </div>
        <div class="readout-cell">
          <div class="readout-label">Jurisdiction</div>
          <div class="readout-value">NJ · USA</div>
        </div>
        <div class="readout-cell">
          <div class="readout-label">NAICS</div>
          <div class="readout-value">541611</div>
        </div>
        <div class="readout-cell">
          <div class="readout-label">Founded</div>
          <div class="readout-value">2023.07.18</div>
        </div>
        <div class="readout-cell">
          <div class="readout-label">Status</div>
          <div class="readout-value signal"><span class="indicator">■</span>OPERATING</div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHO WE'RE FOR / NOT FOR -->
  <section class="module">
    <div class="container">
      <div class="module-classify">
        <span>FIT</span>
        <span class="ref">WHO WE'RE FOR · WHO WE'RE NOT</span>
      </div>

      <div class="protocol">
        <div class="protocol-id">
          A
          <span class="label">FOR</span>
        </div>
        <div class="protocol-body">
          <h4>Who we're for</h4>
          <ul>
            <li>Individuals migrating from exchange custody to self-held cold storage</li>
            <li>Operating businesses adding Bitcoin to treasury</li>
            <li>Engineering teams integrating Lightning or BTCPay</li>
            <li>Founders thinking about privacy + self-hosted infrastructure</li>
            <li>Clients who want documented deliverables, not vibes</li>
          </ul>
        </div>
        <div class="protocol-spec">
          <b>—</b>
          <span class="ln">Sophisticated buyers</span>
          <span class="ln">Hands-on engagements</span>
          <span class="ln">Long-term relationships</span>
        </div>
      </div>

      <div class="protocol">
        <div class="protocol-id">
          B
          <span class="label">NOT FOR</span>
        </div>
        <div class="protocol-body">
          <h4>Who we're not for</h4>
          <ul>
            <li>Anyone seeking financial advice or investment recommendations</li>
            <li>Day-traders or "to the moon" speculators</li>
            <li>Clients who want managed custody (we set you up; you hold the keys)</li>
            <li>Firms looking for a marketplace platform or self-serve tooling</li>
            <li>Engagements that need someone other than the principal operator</li>
          </ul>
        </div>
        <div class="protocol-spec">
          <b>—</b>
          <span class="ln">No financial advice</span>
          <span class="ln">No managed custody</span>
          <span class="ln">No subcontracting</span>
        </div>
      </div>
    </div>
  </section>

  <!-- REFERENCES / PRIOR ART -->
  <section class="module">
    <div class="container container--narrow" style="padding: 0 var(--page-margin);">
      <div class="module-classify">
        <span>PRIOR ART</span>
        <span class="ref">PUBLIC WRITING · COMMUNITY · ENGAGEMENTS</span>
      </div>

      <div class="references">
        <h6>— References &amp; prior work</h6>
        <ol>
          <li>Founder writing: <a href="https://thebitcoinbreakdown.com">The Bitcoin Breakdown</a> · independent Bitcoin education project · 2022–present</li>
          <li>WBIGAF · long-form treatise on Bitcoin's ethical &amp; economic foundations <a href="https://thebitcoinbreakdown.com/guide">[link]</a></li>
          <li>JC Bitcoin Meetup · monthly community education · Jersey City NJ <a href="https://thebitcoinbreakdown.com">[link]</a></li>
          <li>Audited engagements: 50+ self-custody migrations · 12+ node deployments · 3 corporate treasury implementations · 2024–2026</li>
        </ol>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="module">
    <div class="container">
      <div class="module-classify">
        <span>MODULE 04 — DIRECT ENGAGEMENT</span>
        <span class="ref">SCHEDULE A CALL</span>
      </div>
      <h2 class="module-title">Talk to <em>the operator.</em></h2>
      <p class="module-lede">No intermediaries. The person you'd work with is the person you'd talk to.</p>
      <a href="/contact" class="btn btn--primary">Schedule a call</a>
    </div>
  </section>
</BaseLayout>
