---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allGuides = await getCollection('guides', ({ data }) => !data.draft);
const sorted = allGuides.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).toUpperCase();
---
<BaseLayout
  title="Guides — 2112 Capital Solutions"
  description="Documented procedures from real client engagements. Bitcoin custody, AI workflow, privacy, and self-hosted infrastructure. Source-linked, no fluff."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="classify">MODULE 04 — GUIDES · DOCUMENTED PROCEDURES</div>
      <h1>Field guides. <em>Procedures we ship.</em></h1>
      <div class="hero-sub">
        Documented procedures from real client engagements · Bitcoin · AI · Privacy · Self-hosting · Source-linked, traceable, free
      </div>
    </div>
  </section>

  <!-- GUIDES GRID -->
  <section class="module">
    <div class="container">
      <div class="module-classify">
        <span>ALL GUIDES</span>
        <span class="ref">{sorted.length} {sorted.length === 1 ? 'ENTRY' : 'ENTRIES'}</span>
      </div>

      {sorted.length === 0 ? (
        <p class="module-lede">No guides published yet. Check back shortly.</p>
      ) : (
        <div class="card-grid">
          {sorted.map((guide) => (
            <a href={`/guides/${guide.id}`} class="card">
              <div class="card-eyebrow">
                {guide.data.category.toUpperCase()}
                {guide.data.readingTime ? ` · ${guide.data.readingTime.toUpperCase()}` : ''}
              </div>
              <div class="card-title">{guide.data.title}</div>
              <p class="card-excerpt">{guide.data.description}</p>
              <div class="card-meta">
                <span>{fmt(guide.data.pubDate)}</span>
                <span>{guide.data.level.toUpperCase()}</span>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
